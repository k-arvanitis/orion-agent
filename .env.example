# Supabase PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Qdrant Cloud
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Groq
GROQ_API_KEY=your-groq-api-key

# LangSmith
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=orion-agent

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ElevenLabs (voice mode — text-to-speech)
ELEVENLABS_API_KEY=sk_...

# Optional — override defaults shown below
# AGENT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# DENSE_MODEL=BAAI/bge-small-en-v1.5
# SPARSE_MODEL=Qdrant/bm25
# OPERATOR_EMAIL=support-team@shopnova.com.br
# QDRANT_COLLECTION=orion-policies
# VOICE_TRANSCRIBE_MODEL=whisper-large-v3-turbo
# VOICE_TTS_MODEL=eleven_turbo_v2_5
