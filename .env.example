# Supabase PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Qdrant Cloud
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Groq
GROQ_API_KEY=your-groq-api-key

# LangSmith
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=orion-agent

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional — override defaults shown below
# AGENT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# DENSE_MODEL=nomic-embed-text
# SPARSE_MODEL=Qdrant/bm25
# OPERATOR_EMAIL=support-team@shopnova.com.br
# QDRANT_COLLECTION=orion-policies
